{
  "name": "bbsbh",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Tally Baseball companion for scorekeeping, delayed watching, and baseball research.",
  "scripts": {
    "dev": "vite",
    "dev:2": "vite --port 5172",
    "dev:3": "vite --port 5171",
    "dev:4": "vite --port 5170",
    "dev:5": "vite --port 5169",
    "build": "vite build",
    "preview": "vite preview",
    "preview:2": "vite preview --port 4172",
    "preview:3": "vite preview --port 4171",
    "preview:4": "vite preview --port 4170",
    "preview:5": "vite preview --port 4169",
    "lint": "eslint . && node scripts/check-caps.mjs && node scripts/check-name-casing.mjs && node scripts/check-typography.mjs && node scripts/check-focus-ring.mjs && node scripts/check-contrast.mjs && node scripts/check-claude-md.mjs && node scripts/check-report-pages.mjs",
    "check:caps": "node scripts/check-caps.mjs",
    "check:name-casing": "node scripts/check-name-casing.mjs",
    "check:typography": "node scripts/check-typography.mjs",
    "check:focus-ring": "node scripts/check-focus-ring.mjs",
    "check:contrast": "node scripts/check-contrast.mjs",
    "check:claude-md": "node scripts/check-claude-md.mjs",
    "check:report-pages": "node scripts/check-report-pages.mjs",
    "lint:fix": "eslint . --fix",
    "prepare": "git config core.hooksPath .githooks || true",
    "test": "node --test \"test/**/*.test.js\"",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-exclude=\"test/**\" --test-coverage-exclude=\"scripts/**\" \"test/**/*.test.js\"",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@clerk/backend": "^3.11.7",
    "@clerk/clerk-react": "^5.61.9",
    "@fontsource/big-shoulders-display": "^5.2.5",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/ibm-plex-sans-condensed": "^5.2.8",
    "@fontsource/newsreader": "^5.2.10",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/og": "^1.0.0",
    "@vercel/speed-insights": "^2.0.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^0.21.1"
  }
}
