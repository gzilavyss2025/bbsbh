{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/player/:id", "destination": "/api/preview?route=player&id=:id" },
    { "source": "/team/:id/leaders", "destination": "/api/preview?route=team-leaders&id=:id" },
    { "source": "/team/:id", "destination": "/api/preview?route=team&id=:id" },
    { "source": "/leaders/org/:orgId", "destination": "/api/preview?route=leaders-org&orgId=:orgId" },
    { "source": "/leaders/:scope", "destination": "/api/preview?route=leaders&scope=:scope" },
    { "source": "/leaders", "destination": "/api/preview?route=leaders" },
    { "source": "/standings", "destination": "/api/preview?route=standings" },
    { "source": "/prospects", "destination": "/api/preview?route=prospects" },
    { "source": "/rehab", "destination": "/api/preview?route=rehab" },
    { "source": "/about", "destination": "/api/preview?route=about" },
    { "source": "/logos", "destination": "/api/preview?route=logos" },
    { "source": "/:date(\\d{8})/:matchup/:section", "destination": "/api/preview?route=game&date=:date&matchup=:matchup&section=:section" },
    { "source": "/((?!assets/|api/).*)", "destination": "/index.html" }
  ]
}
